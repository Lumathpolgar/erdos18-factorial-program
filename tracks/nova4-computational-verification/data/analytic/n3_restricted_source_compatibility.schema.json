{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "result_class", "source", "sources", "witnesses", "decisions", "scope", "sha256"],
  "properties": {
    "schema": {"const": "nova4.n3-restricted-source-audit.v1"},
    "result_class": {"const": "source compatibility audit"},
    "sources": {"type": "array", "minItems": 3, "maxItems": 3},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}
