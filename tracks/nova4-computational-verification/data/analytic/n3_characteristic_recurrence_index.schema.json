{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nova 3 characteristic recurrence evidence index",
  "type": "object",
  "required": ["schema", "result_class", "source", "generated_evidence_semantic_sha256", "search", "totals", "best_rows", "artifacts", "scope", "sha256"],
  "properties": {
    "schema": {"const": "nova4.n3-characteristic-recurrence-index.v1"},
    "result_class": {"const": "computational evidence"},
    "source": {"type": "object"},
    "generated_evidence_semantic_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "search": {"type": "object"},
    "totals": {"type": "object"},
    "best_rows": {"type": "array", "minItems": 1},
    "artifacts": {"type": "object"},
    "scope": {"type": "string"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
