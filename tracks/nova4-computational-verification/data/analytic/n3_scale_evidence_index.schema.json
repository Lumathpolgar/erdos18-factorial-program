{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nova 3 scale evidence index",
  "type": "object",
  "required": [
    "schema",
    "result_class",
    "source",
    "full_generated_audit_semantic_sha256",
    "n_values",
    "y_grid",
    "scale_rows",
    "grid_tail_rows",
    "theorem_path_rows",
    "files",
    "sha256"
  ],
  "properties": {
    "schema": {"const": "nova4.n3-scale-evidence-index.v1"},
    "result_class": {"const": "computational evidence"},
    "n_values": {"type": "array", "items": {"type": "integer", "minimum": 2}},
    "y_grid": {"type": "array", "items": {"type": "integer", "minimum": 1}},
    "scale_rows": {"type": "integer", "minimum": 1},
    "grid_tail_rows": {"type": "integer", "minimum": 1},
    "theorem_path_rows": {"type": "integer", "minimum": 1},
    "files": {"type": "array", "minItems": 1},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}
