{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nova4.n2-obs-107-range-audit.v1",
  "title": "Nova 2 obstruction finite range audit",
  "type": "object",
  "required": [
    "schema", "result_class", "source_branch", "source_commit", "n_min", "n_max",
    "first_side_condition_n", "first_target_in_half_range_n",
    "first_admissible_failure_n", "later_failures_after_first_admissible",
    "stable_success_through_checked_range_from_n", "transitions"
  ],
  "properties": {
    "schema": {"const": "nova4.n2-obs-107-range-audit.v1"},
    "result_class": {"const": "exact finite theorem audit"},
    "source_branch": {"const": "nova/additive-occupancy"},
    "source_commit": {"pattern": "^[0-9a-f]{40}$"},
    "n_min": {"type": "integer", "minimum": 3},
    "n_max": {"type": "integer", "minimum": 3},
    "first_side_condition_n": {"type": ["integer", "null"]},
    "first_target_in_half_range_n": {"type": ["integer", "null"]},
    "first_admissible_failure_n": {"type": ["integer", "null"]},
    "later_failures_after_first_admissible": {"type": "array"},
    "stable_success_through_checked_range_from_n": {"type": ["integer", "null"]},
    "transitions": {"type": "array"}
  },
  "additionalProperties": false
}
