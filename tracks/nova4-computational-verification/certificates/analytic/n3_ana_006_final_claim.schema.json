{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nova4.n3-variance-limit-claim.v1",
  "type": "object",
  "required": ["schema", "result_class", "source", "evidence_sha256", "claim", "sha256"],
  "properties": {
    "schema": {"const": "nova4.n3-variance-limit-claim.v1"},
    "result_class": {"const": "final theorem audit certificate"},
    "source": {"type": "object"},
    "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim": {"type": "object"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
