{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nova 3 local ceiling claim certificate",
  "type": "object",
  "required": ["schema", "result_class", "source", "claim", "claimed_upper_bound", "sha256"],
  "properties": {
    "schema": {"const": "nova4.n3-local-ceiling-claim.v1"},
    "result_class": {"const": "finite certificate"},
    "claimed_upper_bound": {"type": "integer", "minimum": 0},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
