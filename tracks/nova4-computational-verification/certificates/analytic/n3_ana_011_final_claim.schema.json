{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nova 4 final N3-ANA-011 theorem audit certificate",
  "type": "object",
  "required": ["schema", "result_class", "source", "evidence_sha256", "claim", "sha256"],
  "properties": {
    "schema": {"const": "nova4.n3-ana-011-final-claim.v1"},
    "result_class": {"const": "final theorem audit certificate"},
    "source": {"type": "object"},
    "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim": {"type": "object"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
